# EC2 Enclave KMS 签名演示 - 环境变量示例
# 复制此文件为 .env 并根据您的环境修改配置
# 使用方法: source .env 或在脚本中使用 export

# ============================================
# AWS 配置
# ============================================

# AWS 区域
export AWS_DEFAULT_REGION=us-east-1
export AWS_REGION=us-east-1

# AWS 凭证（如果不使用 IAM 角色）
# 注意: 在 EC2 实例上应该使用 IAM 角色，不要硬编码凭证
# export AWS_ACCESS_KEY_ID=your_access_key_id
# export AWS_SECRET_ACCESS_KEY=your_secret_access_key

# KMS 密钥 ID 或别名
export KMS_KEY_ID=12345678-1234-1234-1234-123456789012
# 或使用别名
# export KMS_KEY_ID=alias/enclave-signing-demo

# ============================================
# Enclave 配置
# ============================================

# Enclave CID（启动后自动分配）
export ENCLAVE_CID=16

# vsock 通信端口
export ENCLAVE_PORT=5000

# Enclave 资源分配
export ENCLAVE_CPU_COUNT=2
export ENCLAVE_MEMORY_MB=512

# 是否启用调试模式（生产环境应设置为 false）
export ENCLAVE_DEBUG_MODE=true

# ============================================
# 通信配置
# ============================================

# 连接超时时间（秒）
export CONNECTION_TIMEOUT=30

# 重试次数
export RETRY_COUNT=3

# 重试延迟（秒）
export RETRY_DELAY=2

# ============================================
# 日志配置
# ============================================

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
export LOG_LEVEL=INFO

# Python 日志配置
export PYTHONUNBUFFERED=1

# ============================================
# 文件路径
# ============================================

# Enclave 镜像文件
export EIF_FILE=enclave.eif

# Enclave CID 文件
export CID_FILE=enclave_cid.txt

# Enclave PCR0 哈希文件
export PCR0_FILE=enclave_pcr0.txt

# KMS 密钥 ID 文件
export KEY_ID_FILE=kms_key_id.txt

# ============================================
# 演示配置
# ============================================

# 默认签名消息
export DEMO_MESSAGE="Hello from EC2 Nitro Enclave Demo!"

# 是否显示详细输出
export VERBOSE=true

# ============================================
# Docker 配置
# ============================================

# Docker 镜像名称
export DOCKER_IMAGE_NAME=enclave-app

# Docker 镜像标签
export DOCKER_TAG=latest

# ============================================
# Python 虚拟环境
# ============================================

# 虚拟环境目录
export VENV_DIR=venv

# Python 版本
export PYTHON_VERSION=3.12

# ============================================
# IAM 配置
# ============================================

# IAM 角色名称
export IAM_ROLE_NAME=EnclaveRole

# IAM 策略名称
export IAM_POLICY_NAME=EnclaveKMSPolicy

# IAM 实例配置文件名称
export INSTANCE_PROFILE_NAME=EnclaveInstanceProfile

# ============================================
# 使用说明
# ============================================

# 1. 复制此文件:
#    cp .env.example .env

# 2. 编辑 .env 文件，修改配置值

# 3. 加载环境变量:
#    source .env

# 4. 验证环境变量:
#    echo $AWS_REGION
#    echo $ENCLAVE_CID

# 5. 运行脚本时会自动使用这些环境变量

# ============================================
# 注意事项
# ============================================

# - 不要将包含敏感信息的 .env 文件提交到版本控制
# - 在 EC2 实例上优先使用 IAM 角色而不是硬编码凭证
# - 生产环境应禁用 Enclave 调试模式
# - 定期轮换 KMS 密钥
# - 使用最小权限原则配置 IAM 角色
